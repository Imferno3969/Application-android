<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ClientUDPActivity">

    <EditText
        android:id="@+id/editTextUDPPort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="0dp"
        android:layout_marginTop="126dp"
        android:hint="Port" />

    <EditText
        android:id="@+id/editTextUDPIP"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/editTextUDPPort"
        android:hint="IP Address" />

    <Button
        android:id="@+id/buttonConnectUDP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/editTextUDPIP"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="20dp"
        android:text="Connect" />

    <EditText
        android:id="@+id/editTextUDPMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/buttonConnectUDP"
        android:layout_alignParentStart="true"
        android:layout_marginStart="4dp"
        android:layout_marginTop="195dp"
        android:hint="Enter Message" />

    <Button
        android:id="@+id/buttonSendUDPMessage"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/editTextUDPMessage"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="23dp"
        android:text="Send Message" />

    <Button
        android:id="@+id/buttonBackToMainUDP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/buttonSendUDPMessage"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="-549dp"
        android:text="Back to Main" />

</RelativeLayout>
