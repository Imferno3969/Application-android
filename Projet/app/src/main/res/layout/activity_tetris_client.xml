<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".ClientUDPActivity">

    <EditText
        android:id="@+id/editTextUDPPort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:layout_marginStart="2dp"
        android:layout_marginTop="52dp"
        android:hint="Port" />

    <EditText
        android:id="@+id/editTextUDPIP"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/editTextUDPPort"
        android:hint="Adresse IP" />

    <Button
        android:id="@+id/buttonConnectUDP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/editTextUDPIP"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="23dp"
        android:text="Connecter" />

    <EditText
        android:id="@+id/editTextUDPMessage"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginStart="13dp"
        android:layout_marginBottom="63dp"
        android:hint="Entrer un Message" />

    <Button
        android:id="@+id/buttonSendUDPMessage"
        android:layout_width="159dp"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="131dp"
        android:text="Envoyer un Message" />

    <Button
        android:id="@+id/buttonBackToMainUDP"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="673dp"
        android:layout_marginBottom="10dp"
        android:text="Retour au menu" />

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="127dp"
        android:layout_height="115dp"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginEnd="266dp"
        app:srcCompat="@android:drawable/ic_menu_myplaces" />

</RelativeLayout>
